<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_hostel_allocation" model="ir.sequence">
            <field name="name">Hostel Allocation</field>
            <field name="code">hostel.allocation</field>
            <field name="prefix">ALL/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_hostel_invoice" model="ir.sequence">
            <field name="name">Hostel Invoice</field>
            <field name="code">hostel.invoice</field>
            <field name="prefix">INV/HOSTEL/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_hostel_tenant" model="ir.sequence">
            <field name="name">Hostel Tenant</field>
            <field name="code">hostel.tenant</field>
            <field name="prefix">TEN/%(year)s/</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>