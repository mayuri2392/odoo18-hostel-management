<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ================================================= -->
    <!-- PORTAL HOME: TILE -->
    <!-- ================================================= -->
<template id="portal_my_home_inherit_hostel"
          inherit_id="portal.portal_my_home"
          name="Portal Home: Stay Overview Tile">

  <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">

    <!-- Wrapper to match width of other tiles -->
    <div class="col-12 mb-3">
      <div style="max-width:420px;">

        <a href="/my/hostel"
           class="d-flex align-items-center text-decoration-none"
           style="
             margin-top:35px;
             background:#f7f7f9;
             border-radius:5px;
             padding:18px 22px;
             min-height:92px;
           ">

          <!-- Icon -->
          <div class="d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:64px;height:64px;margin-right:16px;">
            <i class="fa fa-building-o"
               style="font-size:40px;color:#8fb7ff;"></i>
          </div>

          <!-- Text -->
          <div>
            <div style="font-size:18px;font-weight:400;color:#1f1f1f;line-height:1.2;">
              Stay Overview
            </div>
            <div style="font-size:14px;color:#6c757d;margin-top:4px;line-height:1.3;">
              Room, bed, dates and payments
            </div>
          </div>

        </a>

      </div>
    </div>

  </xpath>

</template>



    <!-- ================================================= -->
    <!-- PORTAL PAGE: STAY OVERVIEW -->
    <!-- ================================================= -->
    <template id="portal_my_hostel" name="Stay Overview">
      <t t-call="portal.portal_layout">

        <!-- ✅ Use portal breadcrumbs WITHOUT _() (prevents NoneType callable crash) -->
        <t t-set="breadcrumbs"
           t-value="[
            {'name': 'My account', 'url': '/my'},
            {'name': 'Stay Overview'}
           ]"/>

        <!-- ✅ Defensive defaults (safe if context ever changes) -->
        <t t-set="tenant" t-value="tenant or False"/>
        <t t-set="current_allocation" t-value="current_allocation or False"/>
        <t t-set="allocations" t-value="allocations or []"/>

        <div class="container o_portal_wrap">


          <!-- Page header -->
          <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">

            <div>
              <h2 class="mb-1">Stay Overview</h2>
              <div class="text-muted small">Your allocation, dates and payment status</div>
            </div>

            <div class="d-flex gap-2">
              <a class="btn btn-primary" href="/my/invoices">
                <i class="fa fa-file-text-o me-1"/> View Invoices
              </a>
            </div>
          </div>

          <t t-if="not tenant">
            <div class="alert alert-warning mb-4">
              <strong>No tenant profile is linked to your account.</strong>
              <div class="small">Please contact the hostel administration.</div>
            </div>
          </t>

          <t t-if="tenant">

            <!-- ========================= -->
            <!-- SUMMARY CARDS -->
            <!-- ========================= -->
            <t t-if="current_allocation">
              <div class="row g-3 mb-4">

                <!-- Due Amount -->
                <div class="col-12 col-md-4">
                  <div class="card h-100">
                    <div class="card-body">
                      <div class="text-muted small mb-1">Due Amount</div>

                      <t t-set="due" t-value="current_allocation.due_amount or 0.0"/>

                      <div class="fw-semibold"
                           t-att-style="'font-size:20px;color:%s;' % ('#dc3545' if due &gt; 0 else '#28a745')">
                        <span t-field="current_allocation.due_amount"
                              t-options="{'widget': 'monetary', 'display_currency': current_allocation.currency_id}"/>
                      </div>

                      <div class="small text-muted mt-1">
                        <t t-if="due &gt; 0">Pending invoice payment</t>
                        <t t-else="">No outstanding dues</t>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Deposit Balance -->
                <div class="col-12 col-md-4">
                  <div class="card h-100">
                    <div class="card-body">
                      <div class="text-muted small mb-1">Security Deposit Balance</div>
                      <div class="fw-semibold" style="font-size:20px;color:#71639e;">
                        <span t-field="current_allocation.deposit_balance"
                              t-options="{'widget': 'monetary', 'display_currency': current_allocation.currency_id}"/>
                      </div>
                      <div class="small text-muted mt-1">Current deposit holding</div>
                    </div>
                  </div>
                </div>

                <!-- Monthly Total -->
                <div class="col-12 col-md-4">
                  <div class="card h-100">
                    <div class="card-body">
                      <div class="text-muted small mb-1">Monthly Total</div>
                      <div class="fw-semibold" style="font-size:20px;color:#212529;">
                        <span t-field="current_allocation.total_monthly_charge"
                              t-options="{'widget': 'monetary', 'display_currency': current_allocation.currency_id}"/>
                      </div>
                      <div class="small text-muted mt-1">Rent + services (monthly)</div>
                    </div>
                  </div>
                </div>

              </div>
            </t>

            <!-- ========================= -->
            <!-- ✅ CURRENT ALLOCATION (more professional layout) -->
            <!-- ========================= -->
            <div class="card mb-4">
              <div class="card-header d-flex align-items-center justify-content-between">
                <div class="fw-semibold">Current Allocation</div>

                <t t-if="current_allocation">
                  <t t-set="st" t-value="current_allocation.state"/>
                  <span class="badge rounded-pill"
                        t-att-class="
                          'bg-success' if st == 'active'
                          else 'bg-warning text-dark' if st == 'draft'
                          else 'bg-secondary' if st == 'checked_out'
                          else 'bg-danger'
                        ">
                    <t t-esc="st.replace('_',' ').title()"/>
                  </span>
                </t>
              </div>

              <div class="card-body">

                <t t-if="not current_allocation">
                  <div class="text-muted">No active allocation found.</div>
                </t>

                <t t-if="current_allocation">

                  <div class="row g-3">

                    <!-- LEFT: Stay Details -->
                    <div class="col-12 col-lg-6">
                      <div class="border rounded-3 p-3 h-100 bg-light">
                        <div class="d-flex align-items-center mb-3">
                          <i class="fa fa-map-marker text-muted me-2"/>
                          <div class="fw-semibold">Stay Details</div>
                        </div>

                        <dl class="row mb-0">
                          <dt class="col-5 col-xl-4 text-muted small">Hostel</dt>
                          <dd class="col-7 col-xl-8 fw-semibold mb-2">
                            <t t-esc="current_allocation.hostel_id.name"/>
                          </dd>

                          <dt class="col-5 col-xl-4 text-muted small">Room</dt>
                          <dd class="col-7 col-xl-8 fw-semibold mb-2">
                            <t t-esc="current_allocation.room_id.name"/>
                          </dd>

                          <dt class="col-5 col-xl-4 text-muted small">Bed</dt>
                          <dd class="col-7 col-xl-8 fw-semibold mb-0">
                            <t t-esc="current_allocation.bed_id.name"/>
                          </dd>
                        </dl>
                      </div>
                    </div>

                    <!-- RIGHT: Dates -->
                    <div class="col-12 col-lg-6">
                      <div class="border rounded-3 p-3 h-100 bg-light">
                        <div class="d-flex align-items-center mb-3">
                          <i class="fa fa-calendar text-muted me-2"/>
                          <div class="fw-semibold">Dates</div>
                        </div>

                        <dl class="row mb-0">
                          <dt class="col-6 text-muted small">Check-in</dt>
                          <dd class="col-6 fw-semibold mb-2">
                            <span t-field="current_allocation.check_in_date"/>
                          </dd>

                          <dt class="col-6 text-muted small">Expected Check-out</dt>
                          <dd class="col-6 fw-semibold mb-2">
                            <t t-if="current_allocation.expected_check_out_date">
                              <span t-field="current_allocation.expected_check_out_date"/>
                            </t>
                            <t t-else="">-</t>
                          </dd>

                          <dt class="col-6 text-muted small">Actual Check-out</dt>
                          <dd class="col-6 fw-semibold mb-0">
                            <t t-if="current_allocation.actual_check_out_date">
                              <span t-field="current_allocation.actual_check_out_date"/>
                            </t>
                            <t t-else="">-</t>
                          </dd>
                        </dl>
                      </div>
                    </div>

                  </div>
                </t>

              </div>
            </div>

            <!-- ========================= -->
            <!-- HISTORY -->
            <!-- ========================= -->
            <div class="card">
              <div class="card-header">
                <div class="fw-semibold">Allocation History</div>
              </div>

              <div class="card-body p-0">
                <t t-if="not allocations">
                  <div class="p-3 text-muted">No allocation history available.</div>
                </t>

                <t t-if="allocations">
                  <div class="table-responsive">
                    <table class="table table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Hostel</th>
                          <th class="text-nowrap">Room</th>
                          <th class="text-nowrap">Bed</th>
                          <th class="text-nowrap">Check-in</th>
                          <th class="text-nowrap">Expected Check-out</th>
                          <th class="text-nowrap">Status</th>
                        </tr>
                      </thead>
                      <tbody>
                        <t t-foreach="allocations" t-as="a">
                          <tr>
                            <td><t t-esc="a.hostel_id.name"/></td>
                            <td class="text-nowrap"><t t-esc="a.room_id.name"/></td>
                            <td class="text-nowrap"><t t-esc="a.bed_id.name"/></td>
                            <td class="text-nowrap"><span t-field="a.check_in_date"/></td>
                            <td class="text-nowrap">
                              <t t-if="a.expected_check_out_date">
                                <span t-field="a.expected_check_out_date"/>
                              </t>
                              <t t-else="">-</t>
                            </td>
                            <td class="text-nowrap">
                              <t t-set="hst" t-value="a.state"/>
                              <span class="badge rounded-pill"
                                    t-att-class="
                                      'bg-success' if hst == 'active'
                                      else 'bg-warning text-dark' if hst == 'draft'
                                      else 'bg-secondary' if hst == 'checked_out'
                                      else 'bg-danger'
                                    ">
                                <t t-esc="hst.replace('_',' ').title()"/>
                              </span>
                            </td>
                          </tr>
                        </t>
                      </tbody>
                    </table>
                  </div>
                </t>
              </div>
            </div>

          </t>
        </div>

      </t>
    </template>



  </data>
</odoo>
