<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hostel Invoice Views -->
    <record id="view_hostel_invoice_list" model="ir.ui.view">
        <field name="name">hostel.invoice.list</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="invoice_date"/>
                <field name="invoice_date_due"/>
                <field name="partner_id"/>
                <field name="hostel_allocation_id"/>
                <field name="amount_total"/>
                <field name="state" widget="badge"/>
                <field name="payment_state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hostel_invoice_search" model="ir.ui.view">
        <field name="name">hostel.invoice.search</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="hostel_allocation_id"/>
                <filter string="Hostel Invoices" name="hostel_invoices" domain="[('hostel_allocation_id', '!=', False)]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft'), ('hostel_allocation_id', '!=', False)]"/>
                <filter string="Posted" name="posted" domain="[('state', '=', 'posted'), ('hostel_allocation_id', '!=', False)]"/>
                <filter string="Paid" name="paid" domain="[('payment_state', '=', 'paid'), ('hostel_allocation_id', '!=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hostel_invoice" model="ir.actions.act_window">
        <field name="name">Hostel Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_hostel_invoice_list"/>
        <field name="search_view_id" ref="view_hostel_invoice_search"/>
        <field name="domain">[('hostel_allocation_id', '!=', False)]</field>
        <field name="context">{'search_default_hostel_invoices': 1}</field>
    </record>


</odoo>